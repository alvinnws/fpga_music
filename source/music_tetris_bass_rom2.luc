// https://musescore.com/user/28837378/scores/5144713
// Adapted from above link
// Comments denote either next bar or note number
// Note number necessary for counter in melody file

module music_tetris_bass_rom2 (
    input num[16],
    output note[5],
    output beat[4]
) {
    const THINGY = $reverse({
            c{5d00, 4d6}, // 0
            //---------
            c{5d09, 4d1},
            c{5d14, 4d1},
            c{5d09, 4d1},
            c{5d14, 4d1},
            c{5d09, 4d1},
            c{5d14, 4d1},
            c{5d09, 4d1},
            c{5d14, 4d1}, // 8
            //---------
            c{5d09, 4d1},
            c{5d13, 4d1},
            c{5d09, 4d1},
            c{5d13, 4d1},
            c{5d09, 4d1},
            c{5d13, 4d1},
            c{5d09, 4d1},
            c{5d13, 4d1}, // 16
            //---------
            c{5d08, 4d1},
            c{5d13, 4d1},
            c{5d08, 4d1},
            c{5d13, 4d1},
            c{5d08, 4d1},
            c{5d13, 4d1},
            c{5d08, 4d1},
            c{5d13, 4d1}, // 24
            //-------
            c{5d09, 4d1},
            c{5d13, 4d1},
            c{5d09, 4d1},
            c{5d13, 4d1},
            c{5d09, 4d4}, // 29
            //--------
            c{5d00, 4d1},
            c{5d01, 4d2},
            c{5d01, 4d1},
            c{5d00, 4d1},
            c{5d01, 4d2},
            c{5d01, 4d1}, // 35
            //--------
            c{5d00, 4d1},
            c{5d02, 4d2},
            c{5d02, 4d1},
            c{5d00, 4d1},
            c{5d02, 4d2},
            c{5d02, 4d1}, // 41
            //--------
            c{5d00, 4d1},
            c{5d01, 4d2},
            c{5d01, 4d1},
            c{5d00, 4d1},
            c{5d01, 4d2},
            c{5d01, 4d1}, // 47
            //--------
            c{5d00, 4d1},
            c{5d02, 4d2},
            c{5d02, 4d1},
            c{5d00, 4d1},
            c{5d02, 4d2},
            c{5d02, 4d1}, // 53
            //--------
            c{5d00, 4d1},
            c{5d01, 4d2},
            c{5d01, 4d1},
            c{5d00, 4d1},
            c{5d01, 4d2},
            c{5d01, 4d1}, // 59
            //--------
            c{5d00, 4d1},
            c{5d02, 4d2},
            c{5d02, 4d1},
            c{5d00, 4d1},
            c{5d02, 4d2},
            c{5d02, 4d1}, // 65
            //-------
            c{5d00, 4d1},
            c{5d01, 4d2},
            c{5d01, 4d1},
            c{5d00, 4d1},
            c{5d01, 4d2},
            c{5d01, 4d1}, // 71
            //--------
            c{5d00, 4d4},
            c{5d02, 4d4}  // 73
        })
    always {
        beat = THINGY[num][3:0]
        note = THINGY[num][8:4]
    }
}