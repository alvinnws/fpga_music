// https://musescore.com/user/28837378/scores/5144713
// Adapted from above link
// Comments denote either next bar or note number
// Note number necessary for counter in melody file

module music_tetris_treble_rom2 (
    input num[16],
    output note[5],
    output beat[4]
) {
    const THINGY = $reverse({
    // (Note freq, Note duration), mapped in note_period_rom and bpm149_rom respectively
            c{5d00, 4d6}, // 0
            //--------
            c{5d00, 4d1},
            c{5d19, 4d2},
            c{5d21, 4d1},
            c{5d23, 4d2},
            c{5d22, 4d1},
            c{5d21, 4d1}, // 6
            //--------
            c{5d20, 4d3},
            c{5d18, 4d1},
            c{5d20, 4d2},
            c{5d19, 4d1},
            c{5d18, 4d1}, // 11
            //--------
            c{5d17, 4d2},
            c{5d17, 4d1},
            c{5d18, 4d1},
            c{5d19, 4d2},
            c{5d20, 4d2}, // 16
            //--------
            c{5d18, 4d2},
            c{5d16, 4d2},
            c{5d16, 4d4}, // 19
            //--------
            c{5d13, 4d4},
            c{5d11, 4d4}, // 21
            //--------
            c{5d12, 4d4},
            c{5d10, 4d4}, // 23
            //--------
            c{5d11, 4d4},
            c{5d09, 4d4}, // 25
            //--------
            c{5d08, 4d4},
            c{5d10, 4d4}, // 27
            //--------
            c{5d13, 4d4},
            c{5d11, 4d4}, // 29
            //--------
            c{5d12, 4d4},
            c{5d10, 4d4}, // 31
            //--------
            c{5d11, 4d2},
            c{5d13, 4d2},
            c{5d16, 4d2},
            c{5d16, 4d2}, // 35
            //--------
            c{5d24, 4d5}  // 36
        })
    
    always {
        beat = THINGY[num][3:0]
        note = THINGY[num][8:4]
          
    }
}