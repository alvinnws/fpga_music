// Adapted from above link
// Comments denote either next bar or note number
// Note number necessary for counter in melody file

module music_never_treble_rom (
    input num[16],
    output note[5],
    output beat[4]
) {
    const THINGY = $reverse({
            c{5d15, 4d1},
            c{5d16, 4d1},
            c{5d18, 4d1},
            c{5d16, 4d1}, // 3
    //-----
            c{5d20, 4d3},
            c{5d20, 4d3},
            c{5d19, 4d5},
            c{5d15, 4d1},
            c{5d16, 4d1},
            c{5d18, 4d1},
            c{5d16, 4d1}, // 10
    //-----
            c{5d19, 4d3},
            c{5d19, 4d3},
            c{5d18, 4d3},
            c{5d17, 4d1},
            c{5d16, 4d2},
            c{5d15, 4d1},
            c{5d16, 4d1},
            c{5d18, 4d1},
            c{5d16, 4d1}, // 19
    //-----
            c{5d18, 4d4},
            c{5d19, 4d2},
            c{5d17, 4d3},
            c{5d16, 4d1},
            c{5d15, 4d4},
            c{5d15, 4d2}, // 25
    //-----
            c{5d19, 4d4},
            c{5d18, 4d6},
            c{5d15, 4d1},
            c{5d16, 4d1},
            c{5d18, 4d1},
            c{5d16, 4d1}, // 31
    //-----
            c{5d20, 4d3},
            c{5d20, 4d3},
            c{5d19, 4d5},
            c{5d15, 4d1},
            c{5d16, 4d1},
            c{5d18, 4d1},
            c{5d16, 4d1}, // 38
    //-----
            c{5d22, 4d4},
            c{5d17, 4d2},
            c{5d18, 4d3},
            c{5d17, 4d1},
            c{5d16, 4d2},
            c{5d15, 4d1},
            c{5d16, 4d1},
            c{5d18, 4d1},
            c{5d16, 4d1}, // 47
    //-----
            c{5d18, 4d4},
            c{5d19, 4d2},
            c{5d17, 4d3},
            c{5d16, 4d1},
            c{5d15, 4d4},
            c{5d15, 4d2}, // 53
    //-----
            c{5d19, 4d4},
            c{5d18, 4d7}  // 55
        })
    
    always {
        beat = THINGY[num][3:0]
        note = THINGY[num][8:4]
          
    }
}