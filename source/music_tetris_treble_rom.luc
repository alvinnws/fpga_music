// https://musescore.com/user/28837378/scores/5144713
// Adapted from above link
// Comments denote either next bar or note number
// Note number necessary for counter in melody file

module music_tetris_treble_rom (
    input num[16],
    output note[5],
    output beat[4]
) {
    const THINGY = $reverse({
            c{5d20, 4d2},
            c{5d17, 4d1},
            c{5d18, 4d1},
            c{5d19, 4d2},
            c{5d18, 4d1},
            c{5d17, 4d1}, // 5
            //--------
            c{5d16, 4d2},
            c{5d16, 4d1},
            c{5d18, 4d1},
            c{5d20, 4d2},
            c{5d19, 4d1},
            c{5d18, 4d1}, // 11
            //--------
            c{5d17, 4d2},
            c{5d17, 4d1},
            c{5d18, 4d1},
            c{5d19, 4d2},
            c{5d20, 4d2}, // 16
            //--------
            c{5d18, 4d2},
            c{5d16, 4d2},
            c{5d16, 4d2},
            c{5d00, 4d2}, // 20
            //--------
            c{5d00, 4d1},
            c{5d19, 4d2},
            c{5d21, 4d1},
            c{5d23, 4d2},
            c{5d22, 4d1},
            c{5d21, 4d1}, // 26
            //--------
            c{5d20, 4d3},
            c{5d18, 4d1},
            c{5d20, 4d2},
            c{5d19, 4d1},
            c{5d18, 4d1}, // 31
            //--------
            c{5d17, 4d2},
            c{5d17, 4d1},
            c{5d18, 4d1},
            c{5d19, 4d2},
            c{5d20, 4d2}, // 36
            //--------
            c{5d18, 4d2},
            c{5d16, 4d2},
            c{5d16, 4d4}, // 39
            //--------
            c{5d20, 4d2},
            c{5d17, 4d1},
            c{5d18, 4d1},
            c{5d19, 4d2},
            c{5d18, 4d1},
            c{5d17, 4d1}, // 45
            //--------
            c{5d16, 4d2},
            c{5d16, 4d1},
            c{5d18, 4d1},
            c{5d20, 4d2},
            c{5d19, 4d1},
            c{5d18, 4d1}, // 51
            //--------
            c{5d17, 4d2},
            c{5d17, 4d1},
            c{5d18, 4d1},
            c{5d19, 4d2},
            c{5d20, 4d2}, // 56
            //--------
            c{5d18, 4d2},
            c{5d16, 4d2},
            c{5d16, 4d2},
            c{5d00, 4d2}, // 60
            //--------
            c{5d00, 4d6}  // 61
        })
    
    always {
        beat = THINGY[num][3:0]
        note = THINGY[num][8:4]
          
    }
}